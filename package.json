{
  "name": "playwright-ast-coverage-monorepo",
  "version": "0.2.3",
  "private": true,
  "description": "Static Playwright AST coverage for Next.js App Router routes",
  "homepage": "https://github.com/jonathanong/playwright-ast-coverage#readme",
  "bugs": {
    "url": "https://github.com/jonathanong/playwright-ast-coverage/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jonathanong/no-mistakes.git"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build:js": "npm --workspaces --if-present run build",
    "test": "vitest run --coverage",
    "test:ci": "vitest run --coverage --reporter=dot --reporter=github-actions",
    "fmt:js": "oxfmt --write packages/ vitest.config.js",
    "fmt:js:check": "oxfmt --check packages/ vitest.config.js",
    "lint:js": "oxlint packages/ vitest.config.js",
    "lint:shell": "shellcheck packages/no-mistakes-scripts/bin/*",
    "lint:spell": "cspell lint README.md \"docs/**/*.md\" \"packages/no-mistakes*/README.md\" cspell.config.yaml package.json --no-progress --no-gitignore --show-suggestions --no-must-find-files",
    "pack:check": "npm --workspaces pack --dry-run",
    "prepare": "husky"
  },
  "devDependencies": {
    "@emnapi/core": "^1.10.0",
    "@emnapi/runtime": "^1.10.0",
    "@vitest/coverage-v8": "^4.1.6",
    "cspell": "^9.8.0",
    "eslint": "^10.3.0",
    "husky": "^9.1.7",
    "oxfmt": "^0.49.0",
    "oxlint": "^1.64.0",
    "vitest": "^4.1.6"
  },
  "engines": {
    "node": "^20.19.0 || ^22.13.0 || >=24"
  }
}
