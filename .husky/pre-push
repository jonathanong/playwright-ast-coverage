#!/bin/sh

# Pre-push hook: checks only; it should not modify tracked files.

remote="$1"
remote_url="$2"

# Fetch the latest main from the actual push destination to ensure comparison is accurate.
echo "Fetching $remote main..."
if ! git fetch "$remote_url" main >/dev/null 2>&1; then
  echo "Error: Could not fetch main from push destination '$remote_url'."
  echo "Please check your network/authentication and retry."
  exit 1
fi

while read local_ref local_sha remote_ref remote_sha
do
  case "$local_ref" in
    refs/heads/*) ;;
    *) continue ;;
  esac

  # Skip main itself and remote branch deletions.
  if [ "$local_ref" = "refs/heads/main" ] || [ "$local_sha" = "0000000000000000000000000000000000000000" ]; then
    continue
  fi

  # Check if the branch being pushed is behind the push destination's main.
  behind_count=$(git rev-list --count "$local_sha"..FETCH_HEAD)
  if [ "$behind_count" -gt 0 ]; then
    echo "Error: Branch '${local_ref#refs/heads/}' is behind $remote main by $behind_count commit(s)."
    echo "Please rebase onto the push destination's main before pushing."
    exit 1
  fi
done

echo "Checking Rust file line limits..."
bash scripts/check-rust-line-limit.sh || exit 1

echo "Checking for inline #[cfg(test)] mod blocks..."
bash scripts/check-rust-test-modules.sh || exit 1

echo "Running cargo fmt..."
cargo fmt --all -- --check || exit 1

echo "Running cargo clippy..."
cargo clippy --all-targets --all-features -- -D warnings || exit 1

echo "Running oxfmt check..."
npm run fmt:js:check || exit 1

echo "Running oxlint..."
npm run lint:js || exit 1

if ! cargo llvm-cov --version >/dev/null 2>&1; then
  echo "Error: cargo-llvm-cov is required for the pre-push coverage check."
  echo "Install it with: cargo install cargo-llvm-cov"
  exit 1
fi

echo "Checking Rust test coverage (100% lines/functions required)..."
cargo llvm-cov --workspace --all-features \
  --ignore-filename-regex 'crates/(next-to-fetch|playwright-ast-coverage|queue-ast-hop|react-traits|server-ast-routes)/src/main\.rs$|crates/(next-to-fetch|queue-ast-hop|react-traits|server-ast-routes)/src/cli\.rs$|crates/next-to-fetch/src/pipeline/route_analysis\.rs$|crates/no-mistakes-core/src/(queue/resolver|server_routes/.*)\.rs$|crates/playwright-ast-coverage/src/analysis/(app_collect|discover|fetch|selectors_index|test_file|tests_report)\.rs$|crates/playwright-ast-coverage/src/playwright_config/(load|parse)\.rs$|crates/playwright-ast-coverage/src/playwright_urls/(literals|visitor)\.rs$|crates/playwright-ast-coverage/src/selectors/call_shapes\.rs$|crates/react-traits/src/pipeline/check\.rs$|crates/server-ast-routes/src/report\.rs$' \
  --fail-under-lines 100 --fail-under-functions 100 --show-missing-lines || exit 1
