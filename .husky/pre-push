#!/bin/sh

# Pre-push hook: checks only; it should not modify tracked files.

remote="$1"
remote_url="$2"

# Fetch the latest main from the actual push destination to ensure comparison is accurate.
echo "Fetching $remote main..."
if ! git fetch "$remote_url" main >/dev/null 2>&1; then
  echo "Error: Could not fetch main from push destination '$remote_url'."
  echo "Please check your network/authentication and retry."
  exit 1
fi

while read local_ref local_sha remote_ref remote_sha
do
  case "$local_ref" in
    refs/heads/*) ;;
    *) continue ;;
  esac

  # Skip main itself and remote branch deletions.
  if [ "$local_ref" = "refs/heads/main" ] || [ "$local_sha" = "0000000000000000000000000000000000000000" ]; then
    continue
  fi

  # Check if the branch being pushed is behind the push destination's main.
  behind_count=$(git rev-list --count "$local_sha"..FETCH_HEAD)
  if [ "$behind_count" -gt 0 ]; then
    echo "Error: Branch '${local_ref#refs/heads/}' is behind $remote main by $behind_count commit(s)."
    echo "Please rebase onto the push destination's main before pushing."
    exit 1
  fi
done

echo "Running no-mistakes check..."
cargo run -p no-mistakes --quiet -- check || exit 1

echo "Running cargo fmt..."
cargo fmt --all -- --check || exit 1

echo "Running cargo clippy..."
cargo clippy --all-targets --all-features -- -D warnings || exit 1

echo "Running oxfmt check..."
npm run fmt:js:check || exit 1

echo "Running oxlint..."
npm run lint:js || exit 1

if ! cargo llvm-cov --version >/dev/null 2>&1; then
  echo "Error: cargo-llvm-cov is required for the pre-push coverage check."
  echo "Install it with: cargo install cargo-llvm-cov"
  exit 1
fi

echo "Checking Rust test coverage (99% lines/functions required)..."
cargo llvm-cov --workspace --all-features \
  --ignore-filename-regex 'crates/(no-mistakes|next-to-fetch|playwright-ast-coverage|queue-ast-hop|react-traits|server-ast-routes)/src/main\.rs$|crates/(next-to-fetch|queue-ast-hop|react-traits|server-ast-routes)/src/cli\.rs$|crates/next-to-fetch/src/pipeline/route_analysis\.rs$|crates/no-mistakes-core/src/(codebase/.*|queue/resolver|server_routes/.*)\.rs$|crates/playwright-ast-coverage/src/analysis/(app_collect|discover|duplicates|fetch|pipeline|selectors_index|test_file|tests_report)\.rs$|crates/playwright-ast-coverage/src/(config|fsutil)\.rs$|crates/playwright-ast-coverage/src/playwright_config/(load|parse)\.rs$|crates/playwright-ast-coverage/src/playwright_urls/(literals|statics|visitor)\.rs$|crates/playwright-ast-coverage/src/selectors/(call_shapes|css|extract_app|extract_playwright|matcher|scoped_defaults|template)\.rs$|crates/no-mistakes-core/src/react_traits/analyze/(components|jsx_children)\.rs$|crates/no-mistakes-core/src/react_traits/analyze/components/helpers\.rs$|crates/no-mistakes-core/src/react_traits/pipeline/(check|glob|run)\.rs$|crates/no-mistakes-core/src/react_traits/traits/(props|suspense)\.rs$|crates/server-ast-routes/src/report\.rs$|crates/queue-ast-hop/src/report/mod\.rs$|crates/no-mistakes-core/src/(ast|routes)\.rs$|crates/no-mistakes-core/src/fetch/(file_analysis|import_routes|imports|resolve|visitor)\.rs$|crates/no-mistakes-core/src/queue/(extract|extract_helpers|graph|graph_model)\.rs$|crates/next-to-fetch/src/pipeline/(run|target)\.rs$|crates/no-mistakes-core/src/config/v2/(discover|legacy)\.rs$|crates/no-mistakes/src/(check|react)\.rs$' \
  --fail-under-lines 99 --fail-under-functions 99 --show-missing-lines || exit 1
