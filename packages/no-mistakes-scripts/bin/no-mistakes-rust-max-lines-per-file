#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'USAGE'
no-mistakes-rust-max-lines-per-file

Enforce maximum Rust code lines per file.

Usage:
  no-mistakes-rust-max-lines-per-file [options] <src_or_tests_dir> [<src_or_tests_dir>...]
  no-mistakes-rust-max-lines-per-file --help

Options:
  --src-max <lines>    Maximum code lines in source files (default: 200)
  --test-max <lines>   Maximum code lines in test files (default: 500)
  --exclude <path>     Pass an exclude path to tokei; repeatable

Requires:
  tokei
  jq

Examples:
  no-mistakes-rust-max-lines-per-file crates/no-mistakes/src
  no-mistakes-rust-max-lines-per-file crates/no-mistakes/src crates/no-mistakes/tests
  no-mistakes-rust-max-lines-per-file crates/*/src crates/*/tests
USAGE
}

require_positive_int() {
  case "$2" in
    ''|0|*[!0-9]*)
      echo "Error: $1 requires a positive integer." >&2
      usage >&2
      exit 2
      ;;
  esac
}

src_max=200
test_max=500
fail=0
tokei_excludes=()
paths=()

while [ "$#" -gt 0 ]; do
  case "$1" in
    -h|--help)
      usage
      exit 0
      ;;
    --src-max)
      if [ "$#" -lt 2 ]; then
        echo "Error: --src-max requires a value." >&2
        exit 2
      fi
      require_positive_int "--src-max" "$2"
      src_max="$2"
      shift 2
      ;;
    --test-max)
      if [ "$#" -lt 2 ]; then
        echo "Error: --test-max requires a value." >&2
        exit 2
      fi
      require_positive_int "--test-max" "$2"
      test_max="$2"
      shift 2
      ;;
    --exclude)
      if [ "$#" -lt 2 ] || [ -z "${2:-}" ]; then
        echo "Error: --exclude requires a non-empty value." >&2
        exit 2
      fi
      tokei_excludes+=(--exclude "$2")
      shift 2
      ;;
    --)
      shift
      while [ "$#" -gt 0 ]; do
        paths+=("$1")
        shift
      done
      ;;
    -*)
      echo "Error: unknown option $1" >&2
      usage >&2
      exit 2
      ;;
    *)
      paths+=("$1")
      shift
      ;;
  esac
done

if [ "${#paths[@]}" -lt 1 ]; then
  usage >&2
  exit 2
fi

if ! command -v tokei >/dev/null 2>&1; then
  echo "Error: tokei is required." >&2
  echo "  macOS: brew install tokei" >&2
  echo "  Linux/macOS: cargo install tokei" >&2
  exit 1
fi

if ! command -v jq >/dev/null 2>&1; then
  echo "Error: jq is required." >&2
  echo "  macOS: brew install jq" >&2
  echo "  Linux: apt-get install jq" >&2
  exit 1
fi

line_limit_for_file() {
  local root="$1"
  local file="$2"
  local normalized

  normalized="${file//\\//}"
  if [ "$(basename "$root")" = "tests" ] || [ "$(basename "$normalized")" = "tests.rs" ] || [[ "$normalized" == */tests/* ]]; then
    echo "$test_max"
  else
    echo "$src_max"
  fi
}

check_dir() {
  local dir="$1"
  local json
  json=$(tokei "$dir" --files --output json ${tokei_excludes[@]+"${tokei_excludes[@]}"})

  while IFS=$'\t' read -r lines file; do
    local max
    max=$(line_limit_for_file "$dir" "$file")
    if [ -n "$file" ] && [ "$lines" -gt "$max" ]; then
      echo "::error file=$file::$file has $lines code lines (max $max) - split into smaller modules"
      fail=1
    fi
  done < <(printf '%s' "$json" | jq -r '.Rust?.reports[]? | [.stats.code, .name] | @tsv')
}

for path in "${paths[@]}"; do
  check_dir "$path"
done

if [ "$fail" -eq 0 ]; then
  echo "All Rust files within line limits."
fi

exit "$fail"
